# Copy this file to `.env` (which is git-ignored) and fill in real values.
# NEVER commit `.env`. Secrets belong here or in Docker secrets — never in source.

# --- Postgres (single source of truth; the app + Grafana read these) ---------
POSTGRES_USER=fintracker
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=fintracker

# --- Timezone (used by the scheduler) ----------------------------------------
TZ=Europe/Madrid

# --- Scheduling --------------------------------------------------------------
# Daily market ingest (local time, after US close). 22:30 Madrid ~ post-close.
DAILY_HOUR=22
DAILY_MINUTE=30
# Daily SEC fundamentals check (cheap; acts only on new filings).
SEC_HOUR=23
SEC_MINUTE=0
# Daily earnings-date check (alongside prices).
EARNINGS_HOUR=22
EARNINGS_MINUTE=45
# Weekly email report (from milestone 6). Monday 08:00 by default.
WEEKLY_DAY=mon
WEEKLY_HOUR=8
WEEKLY_MINUTE=0
# Daily Spain housing (INE) ingest. Quarterly data, so morning is fine.
HOUSING_HOUR=6
HOUSING_MINUTE=30
# Run one market + housing ingest immediately on boot (handy the first time).
RUN_ON_START=true

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO

# --- Grafana -----------------------------------------------------------------
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-admin

# --- Email (weekly report; leave unset to skip sending) -----------------------
# Use a dedicated Gmail app password (Google Account -> Security -> App
# passwords), never your account password. Rotate it if it ever leaks.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-account@gmail.com
EMAIL_PASS=paste-a-gmail-app-password
EMAIL_TO=your-email@example.com
# How many days back the weekly report's short-window price move looks.
REPORT_LOOKBACK_DAYS=7
# Comma-separated symbols the weekly report covers (e.g. UNH,BN,BTC).
# Leave empty to include every tracked instrument.
REPORT_SYMBOLS=

# --- SEC (used from milestone 4 onward) --------------------------------------
# SEC requires a descriptive User-Agent WITH a contact email, or it returns 403.
SEC_USER_AGENT=fintracker/0.1 (your-email@example.com)

# --- Crypto ------------------------------------------------------------------
# Crypto uses CoinGecko's free, no-key API — no API key is needed.

# --- Interest rates ----------------------------------------------------------
# Interest rates come from FRED's and the ECB Data Portal's free CSV endpoints
# — no API key needed for either.

# --- Spain housing (Grafana "Spain Housing" dashboard) -----------------------
# Regional series (población, renta, ...) come from INE's free, key-less Tempus3
# JSON API — no key needed. INE_BASE_URL rarely changes. No placeholder/"sample"
# data is ever written: an indicator with no live table configured stays empty.
INE_BASE_URL=https://servicios.ine.es/wstempus/js/ES
# INE series are fetched by DATOS_TABLA/<table id> (the jaxiT3 "t=<id>" number).
# Población works out of the box from table 2852 ("Población por provincias y
# sexo"); CCAA + national are summed from provinces. Override only if needed:
INE_POBLACION_PROV_TABLE=
# Renta. CCAA-level renta is LIVE by default from the compact ECV tables
# (9947 per person, 9949 per household). The overrides below are optional:
#   * INE_RENTA_PROV_TABLE / INE_RENTA_HOGAR_TABLE — replace the CCAA table for
#     the per-person / per-household series.
#   * INE_RENTA_MUNI_TABLES — comma-separated ADRH province table ids for
#     MUNICIPAL renta (e.g. 31097 Madrid, 30896 Barcelona; browse at
#     ine.es/jaxiT3/Tabla.htm?t=<id>). District/section rows are dropped. Each
#     ADRH table is ~30k series, so add only the provinces you want and never
#     all 54 at once (that would OOM the ingest). Province renta has no compact
#     table, so it is left empty unless you pin one here.
INE_RENTA_PROV_TABLE=
INE_RENTA_HOGAR_TABLE=
INE_RENTA_MUNI_TABLES=
#
# Not pulled by this JSON ingest — see the README "Notes on data sources":
#   * Dwelling counts (viviendas) DO exist in Tempus3 (candidate table 3457,
#     "Viviendas ... por tipo ... por CCAA y provincias") but are not wired yet.
#   * Mean dwelling floor area (m2) and mean dwelling age (año de construcción)
#     are published ONLY as PC-Axis (.px) census tables, not via this JSON API.
#   * Territory area (km2) — and therefore the derived density — has no clean
#     Tempus3 series. These indicators stay empty until sourced another way.
#
# House prices (€/m²) come from the Ministerio de Vivienda's "BoletinOnline"
# .XLS files ("Valor tasado de la vivienda"). These URLs are the built-in
# defaults (35101000 all, 35101500 new, 35102000 second-hand, 35102500
# protected/VPO) and are still current — set a var only to override.
MIVAU_PRICE_URL=https://apps.fomento.gob.es/BoletinOnline2/sedal/35101000.XLS
MIVAU_PRICE_NEW_URL=https://apps.fomento.gob.es/BoletinOnline2/sedal/35101500.XLS
MIVAU_PRICE_USED_URL=https://apps.fomento.gob.es/BoletinOnline2/sedal/35102000.XLS
MIVAU_PROTECTED_URL=https://apps.fomento.gob.es/BoletinOnline2/sedal/35102500.XLS
#
# --- Market-activity series (all OFF by default; pin an id/URL to enable) -----
# These sit alongside the €/m² prices, pinned by id (never auto-discovered).
# compraventa (table 6149) and hipoteca (table 3232) are LIVE by default; the
# vars below are overrides. IPV, land price and permits still need an id/URL.
INE_COMPRAVENTA_TABLE=
# House Price Index (IPV) — INE operation 15, quarterly, national + CCAA, general
# index. Pin the by-CCAA general-index table id (TABLAS_OPERACION/15) to enable.
INE_IPV_TABLE=
# Mortgages — override the default table 3232 (e.g. with a newer "base" table).
INE_HIPOTECA_TABLE=
# Urban land price (€/m² de suelo) — a BoletinOnline .XLS like the price files;
# set the full sedal URL once you confirm its code.
MIVAU_SUELO_URL=
# New-build permits (visados de dirección de obra) — a BoletinOnline .XLS; set
# the full sedal URL once you confirm its code.
MIVAU_VISADOS_URL=
#
# --- Census housing characteristics (PC-Axis .px; all OFF by default) ---------
# The Censo 2021 dwelling detail is published only as .px files (ingest_censo
# reads them). Set the full .px URL for each to enable it; the dimension/category
# names in ingest_censo.CENSO_SPECS are best-effort — inspect a real .px on the
# server (parse_px) and adjust if a series comes back empty. Mean floor area and
# mean age are computed as weighted means of the band distributions.
CENSO_VIVIENDAS_PX_URL=
CENSO_SUPERFICIE_PX_URL=
CENSO_ANTIGUEDAD_PX_URL=
