# Copy this file to `.env` (which is git-ignored) and fill in real values.
# NEVER commit `.env`. Secrets belong here or in Docker secrets — never in source.

# --- Postgres (single source of truth; the app + Grafana read these) ---------
POSTGRES_USER=fintracker
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=fintracker

# --- Timezone (used by the scheduler) ----------------------------------------
TZ=Europe/Madrid

# --- Scheduling --------------------------------------------------------------
# Daily market ingest (local time, after US close). 22:30 Madrid ~ post-close.
DAILY_HOUR=22
DAILY_MINUTE=30
# Daily SEC fundamentals check (cheap; acts only on new filings).
SEC_HOUR=23
SEC_MINUTE=0
# Daily earnings-date check (alongside prices).
EARNINGS_HOUR=22
EARNINGS_MINUTE=45
# Weekly email report (from milestone 6). Monday 08:00 by default.
WEEKLY_DAY=mon
WEEKLY_HOUR=8
WEEKLY_MINUTE=0
# Run one market ingest immediately on boot (handy the first time). true/false.
RUN_ON_START=true

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO

# --- Grafana -----------------------------------------------------------------
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-admin
# Public URL of your Grafana, linked from the weekly email.
GRAFANA_URL=http://localhost:3000

# --- Email (used from milestone 6 onward) ------------------------------------
# IMPORTANT: the Gmail app password shared earlier in plaintext is COMPROMISED.
# Revoke it (Google Account -> Security -> App passwords), generate a fresh one,
# and paste the NEW value here. Never put it back in source.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=autoscaremail@gmail.com
EMAIL_PASS=paste-a-freshly-generated-app-password
EMAIL_TO=oscarprietoamigo@gmail.com
# How many days back the weekly report looks for moves / new filings.
REPORT_LOOKBACK_DAYS=7

# --- SEC (used from milestone 4 onward) --------------------------------------
# SEC requires a descriptive User-Agent WITH a contact email, or it returns 403.
SEC_USER_AGENT=fintracker/0.1 (oscarprietoamigo@gmail.com)

# --- Crypto ------------------------------------------------------------------
# Crypto uses CoinGecko's free, no-key API — no CoinMarketCap key is needed.
# (The previously hardcoded CMC key should be revoked; it is no longer used.)
